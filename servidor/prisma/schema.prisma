generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id                    String      @id @default(uuid())
  nome                  String
  slug                  String      @unique
  cnpj                  String?
  telefone              String?
  endereco              String?
  logo                  String?     // URL da imagem
  corPrimaria           String?     @default("indigo")
  instagram             String?
  facebook              String?
  horarioFuncionamento  Json?       // Estrutura de horários semanais
  
  // Gestão de Assinatura (SaaS)
  plano                 String      @default("TRIAL") // TRIAL, STARTER, PRO, PREMIUM
  statusAssinatura      String      @default("ATIVO") // ATIVO, CANCELADO, INADIMPLENTE
  dataVencimento        DateTime?
  
  // Configurações de Negócio
  exigirPagamentoAntecipado Boolean @default(false)
  customLabels              Json?    // Ex: { "profissional": "Barbeiro", "servico": "Serviço", "cliente": "Cliente" }
  
  // Configurações de Automação
  autoLembrete          Boolean     @default(true)
  autoAniversario       Boolean     @default(false)
  autoAvaliacao         Boolean     @default(true)
  autoBloqueioFalta     Boolean     @default(false)
  
  // Integração WhatsApp API (Evolution, WPPConnect, etc)
  whatsappApiUrl        String?
  whatsappApiToken      String?
  whatsappInstanceName  String?
  msgBoasVindasAtiva    Boolean     @default(false)
  msgLembreteAtiva      Boolean     @default(false)

  usuarios              Usuario[]
  servicos              Servico[]
  agendamentos          Agendamento[]
  bloqueios             BloqueioAgenda[]
  transacoes            Transacao[]
  clientes              Cliente[]
  cupons                Cupom[]
  logsAuditoria         LogAuditoria[]
  chamadosSuporte       ChamadoSuporte[]
  faturas               Fatura[]
  adicionais            Adicional[]
  camposFormulario      CampoFormulario[]
  notificacoes          Notificacao[]

  criadoEm              DateTime    @default(now())
  atualizadoEm          DateTime    @updatedAt

  @@map("empresas")
}

model Fatura {
  id          String    @id @default(uuid())
  codigo      String    @unique // Ex: FAT-2026-001
  data        DateTime  @default(now())
  valor       Int       // Em centavos
  status      String    @default("PAGO") // PAGO, PENDENTE, CANCELADO
  plano       String
  empresaId   String
  empresa     Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("faturas")
}

model Usuario {
  id                 String        @id @default(uuid())
  nome               String
  email              String        @unique
  telefone           String?       @unique
  senha              String
  role               RoleUsuario   @default(DONO)
  isProfissional     Boolean       @default(false)
  horariosDeTrabalho Json?
  foto               String?
  empresaId          String
  criadoEm           DateTime      @default(now())
  atualizadoEm       DateTime      @updatedAt
  agendamentos       Agendamento[]
  transacoes         Transacao[]
  bloqueios          BloqueioAgenda[]
  empresa            Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("usuarios")
}

model Servico {
  id                String        @id @default(uuid())
  nome              String
  descricao         String?
  duracao           Int
  preco             Int
  capacidadeMaxima  Int           @default(1)
  tempoBuffer       Int           @default(0) // Tempo de preparo em minutos
  ativo             Boolean       @default(true)
  empresaId         String
  agendamentos      Agendamento[]
  empresa           Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("servicos")
}

model Cliente {
  id           String        @id @default(uuid())
  nome         String
  sobrenome    String?
  telefone     String
  email        String?
  notas        String?
  empresaId    String
  criadoEm     DateTime      @default(now())
  atualizadoEm DateTime      @updatedAt
  agendamentos Agendamento[]
  empresa      Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("clientes")
}

model Agendamento {
  id             String            @id @default(uuid())
  dataHora       DateTime
  status         StatusAgendamento @default(PENDENTE)
  valorTotal     Int
  empresaId      String
  clienteId      String
  profissionalId String
  servicoId      String
  criadoEm       DateTime          @default(now())
  atualizadoEm   DateTime          @updatedAt
  cliente        Cliente           @relation(fields: [clienteId], references: [id])
  empresa        Empresa           @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  profissional   Usuario           @relation(fields: [profissionalId], references: [id])
  servico        Servico           @relation(fields: [servicoId], references: [id])
  transacao      Transacao?
  adicionais     Adicional[]       @relation("AdicionalToAgendamento")
  respostasExtras Json?

  @@map("agendamentos")
}

model Adicional {
  id           String        @id @default(uuid())
  nome         String
  descricao    String?
  preco        Int
  ativo        Boolean       @default(true)
  empresaId    String
  empresa      Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  agendamentos Agendamento[] @relation("AdicionalToAgendamento")

  @@map("adicionais")
}

model Transacao {
  id            String        @id @default(uuid())
  tipo          TipoTransacao
  categoria     String
  descricao     String
  valor         Int
  data          DateTime      @default(now())
  empresaId     String
  responsavelId String?
  agendamentoId String?       @unique
  criadoEm      DateTime      @default(now())
  agendamento   Agendamento?  @relation(fields: [agendamentoId], references: [id])
  empresa       Empresa       @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  responsavel   Usuario?      @relation(fields: [responsavelId], references: [id])

  @@map("transacoes")
}

model Cupom {
  id           String   @id @default(uuid())
  codigo       String   @unique
  desconto     Int      // Valor em porcentagem ou centavos
  tipo         String   @default("PERCENTUAL") // PERCENTUAL ou FIXO
  validade     DateTime?
  status       String   @default("ATIVO") // ATIVO, INATIVO
  usos         Int      @default(0)
  limiteUso    Int      @default(0) // 0 = ilimitado
  empresaId    String
  empresa      Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  criadoEm     DateTime @default(now())

  @@map("cupons")
}

enum RoleUsuario {
  ADMIN
  DONO
  RECEPCIONISTA
  PROFISSIONAL
}

enum StatusAgendamento {
  PENDENTE
  CONFIRMADO
  CONCLUIDO
  CANCELADO
  NOSHOW
}

enum TipoTransacao {
  ENTRADA
  SAIDA
}

model BloqueioAgenda {
  id             String   @id @default(uuid())
  empresaId      String
  profissionalId String?  // Se nulo, bloqueia a loja toda
  inicio         DateTime
  fim            DateTime
  motivo         String?
  recorrente     Boolean  @default(false)
  empresa        Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  profissional   Usuario? @relation(fields: [profissionalId], references: [id], onDelete: SetNull)

  @@map("bloqueios_agenda")
}

model LogAuditoria {
  id          String    @id @default(uuid())
  dataHora    DateTime  @default(now())
  usuario     String    // Nome ou email do autor
  acao        String    // Descrição (ex: "Excluiu agendamento")
  tipo        String    @default("INFO") // INFO, WARNING, DANGER
  empresaId   String
  empresa     Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("logs_auditoria")
}

model ChamadoSuporte {
  id          String    @id @default(uuid())
  assunto     String
  mensagem    String
  status      String    @default("ABERTO") // ABERTO, EM_ANDAMENTO, FECHADO
  prioridade  String    @default("NORMAL")
  empresaId   String
  empresa     Empresa   @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  criadoEm    DateTime  @default(now())

  @@map("chamados_suporte")
}

model CampoFormulario {
  id          String   @id @default(uuid())
  label       String   // Pergunta, ex: "Raça do Pet" ou "Placa do Veículo"
  tipo        String   @default("TEXT") // TEXT, NUMBER, SELECT
  opcoes      Json?    // Opções se for SELECT (ex: ["Pequeno", "Médio", "Grande"])
  obrigatorio Boolean  @default(false)
  ativo       Boolean  @default(true)
  empresaId   String
  empresa     Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@map("campos_formulario")
}

model Notificacao {
  id          String   @id @default(uuid())
  titulo      String
  mensagem    String
  lida        Boolean  @default(false)
  tipo        String   @default("INFO") // INFO, SUCCESS, WARNING, DANGER
  empresaId   String
  empresa     Empresa  @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  criadoEm    DateTime @default(now())

  @@map("notificacoes")
}
